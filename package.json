{
  "name": "tendersentinel-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "Tailwind CSS build for TenderSentinel's server-rendered templates.",
  "scripts": {
    "build:css": "tailwindcss -i ./web/static/css/input.css -o ./web/static/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./web/static/css/input.css -o ./web/static/css/tailwind.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "tailwindcss": "^3.4.19"
  }
}
