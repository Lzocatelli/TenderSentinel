# Copy this file to .env and fill in real values for local development.
# In production (Railway), set these as environment variables instead.

# ── Core ──────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=
BASE_URL=http://localhost:8080

# ── Database ──────────────────────────────────────────────────────────────
# Either DATABASE_URL or the individual DB_* vars below.
DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# ── SAM.gov ───────────────────────────────────────────────────────────────
SAM_API_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASICO=
STRIPE_PRICE_PROFISSIONAL=
STRIPE_PRICE_AGENCIA=
STRIPE_PRICE_BASICO_ANUAL=
STRIPE_PRICE_PROFISSIONAL_ANUAL=
STRIPE_PRICE_AGENCIA_ANUAL=

# ── Email (checked in this order: SES > SendGrid > Gmail SMTP) ───────────
# Amazon SES (recommended for production — cheap, generous limits).
# SES_FROM_EMAIL must be a verified identity in the SES console; new SES
# accounts start in "sandbox mode" and can only send to verified recipient
# addresses until you request production access from AWS.
SES_FROM_EMAIL=
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# SendGrid (used only if SES_FROM_EMAIL is unset)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
# Gmail SMTP fallback (used only if neither of the above is set)
EMAIL_REMETENTE=
EMAIL_SENHA=
ADMIN_EMAIL=
TEST_EMAIL=

# ── Google OAuth (optional — "Continue with Google" is hidden if unset) ──
# Create a Web Application OAuth client at:
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI opportunity summaries (optional — endpoint returns 503 if unset) ──
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Defaults to a small/fast model; override if you want a different one.
AI_SUMMARY_MODEL=claude-haiku-4-5-20251001
